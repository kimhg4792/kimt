<!DOCTYPE html>
<html>
    <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta http-equiv="X-UA-Compatible" content="ie=edge">
      <link rel="stylesheet" href="/stylesheets/style.css" />
      <link rel="stylesheet" href="bootstrap/bootstrap.min.css" >
      <title>DaikoIWS-KT</title>
      <link rel='stylesheet' href='stylesheets/reset.css' />
    </head>
    <body>
      <header class="p-3 bg-light text-white sticky">
        <div>
            <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
                <a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none">
                  <img src="/images/daikoiws_logo.png">
                </a>
            
                <ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
                  <li class="nav-px-1-5"><a href="/tetris" class="nav-link px-2 font-1-3 text-dark">tetris</a></li>
                  <li class="nav-px-1-5"><a href="/dbCheck" class="nav-link px-2 font-1-3 text-dark">DBcheck</a></li>
                  <li class="nav-px-1-5"><a href="/study" class="nav-link px-2 font-1-3 text-dark">Study</a></li>
                  <li class="nav-px-1-5"><a href="/paint" class="nav-link px-2 font-1-3 text-dark">Paint</a></li>
                  <li class="nav-px-1-5"><a href="/chart" class="nav-link px-2 font-1-3 text-dark">chart</a></li>
                  <li>
                    
                  </li>
                </ul>
                
                <% if( !user_uid ) { %>
                <div class="text-end">
                  <button onclick="location.href='/login'" type="button" style="background-color: #62C15B;" class="btn btn-outline-light me-2">Login</button>
                  <button onclick="location.href='/sign-up'" type="button" style="background-color: #2478FF;" class="btn btn-outline-light">Sign-up</button>
                </div>
                <% } else { %>
                <div class="text-end" style="display: flex;">
                  <li class="nav-link px-2 font-1-3 text-dark me-4" style="padding-top: .5rem;">Login: <%= user_uid %> 様</li>
                  <button onclick="location.href='/logout'" style="background-color: #FF2424" type="button" class="btn btn-outline-light">Logout</button>
                </div>
                <% } %>
            </div>
        </div>
      </header>

        <canvas id="jsCanvas" class="canvas" style="width:100%; height:100%;"></canvas>
        <div class="controls">
            <div class="controls__range">
                <input 
                type="range" 
                id="jsRange" 
                min="0.1" 
                max="5" 
                value="2.5" 
                step="0.1"
                />
            </div>
            <div class="controls__btns">
                <button id="jsMode">Fill</button>
                <button id="jsSave">Save</button>
            </div>
            <div class="controls__colors" id="jsColors">
                <div class="controls__color jsColor" style="background-color:#2c2c2c"></div>
                <div class="controls__color jsColor" style="background-color:white"></div>
                <div class="controls__color jsColor" style="background-color:#FF3B30"></div>
                <div class="controls__color jsColor" style="background-color:#FF9500"></div>
                <div class="controls__color jsColor" style="background-color:#FFCC00"></div>
                <div class="controls__color jsColor" style="background-color:#4CD963"></div>
                <div class="controls__color jsColor" style="background-color:#5AC8FA"></div>
                <div class="controls__color jsColor" style="background-color:#0579FF"></div>
                <div class="controls__color jsColor" style="background-color:#5856D6"></div>
            </div>
        </div>
        <script src="http://localhost:3000/javascript/paint.js"></script>
    
</html>